# ==============================================================================
# VedicScan Backend — Environment Configuration
#
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Variables marked REQUIRED must be set or the server will not work correctly.
# ==============================================================================


# ─── Core ─────────────────────────────────────────────────────────────────────

# development | production | test
NODE_ENV=development

# Port the HTTP server binds to.
PORT=8001

# Comma-separated CORS allowlist for browser clients.
# Leave empty in development to reflect any origin. SET THIS IN PRODUCTION.
FRONTEND_URL=


# ─── MongoDB (REQUIRED) ───────────────────────────────────────────────────────
# Where: MongoDB Atlas → Database → Connect → Drivers, or your local mongod.

MONGO_URL=mongodb://localhost:27017
DB_NAME=vedicscan


# ─── Authentication (REQUIRED) ────────────────────────────────────────────────

# Signing key for user JWTs. Must be a strong random string of >= 32 characters —
# the server REFUSES TO BOOT in production with a weak or missing value, because
# a guessable secret lets anyone forge an admin token.
# Generate: openssl rand -base64 48
JWT_SECRET=

JWT_EXPIRES_IN=7d


# ─── RevenueCat (REQUIRED for mobile subscriptions) ───────────────────────────
# RevenueCat is the single source of truth for all subscription state.

# Secret API key used for SERVER-SIDE entitlement verification.
# Where: RevenueCat Dashboard → Project Settings → API Keys → Secret keys ("sk_...")
#
# SECURITY: this is a server-only credential. It must never be shipped in the
# mobile app or exposed to a browser — the app uses the separate PUBLIC SDK key.
# Without it, /api/billing/sync and restore-purchases cannot verify entitlements
# and will return 503 rather than trusting the client.
REVENUECAT_SECRET_KEY=

# Static bearer token authenticating incoming RevenueCat webhooks.
# Where: RevenueCat Dashboard → Project Settings → Integrations → Webhooks →
#        Authorization header. Set the SAME value in both places.
#
# SECURITY: this is the only thing protecting an endpoint that grants premium
# access. If unset, the webhook route rejects EVERY request (fail closed) rather
# than accepting unauthenticated events. Generate: openssl rand -hex 32
REVENUECAT_WEBHOOK_AUTH_TOKEN=

# Process SANDBOX (test purchase) webhook events even when NODE_ENV=production.
# Sandbox purchases cost nothing, so leaving this true in production would let
# anyone with a Play test account mint free premium. Keep FALSE in production.
REVENUECAT_ALLOW_SANDBOX=true

# Optional: override the RevenueCat API host and request timeout.
# REVENUECAT_API_BASE_URL=https://api.revenuecat.com
# REVENUECAT_TIMEOUT_MS=8000


# ─── Store product IDs ────────────────────────────────────────────────────────
# Consumed ONLY by the billing seeder to populate each plan's storeProductIds.
# Where: Google Play Console → Monetise → Subscriptions / In-app products.
# After seeding, these live in MongoDB; edit the plan documents to change them.

PRODUCT_ID_STANDARD_MONTHLY=vedicscan_standard_monthly
PRODUCT_ID_STANDARD_YEARLY=vedicscan_standard_yearly
PRODUCT_ID_ADDON_PACK=vedicscan_addon_pack


# ─── Billing behaviour ────────────────────────────────────────────────────────

# Global paywall kill switch. Enforcement is ON unless this is exactly "false".
# Set false ONLY as an emergency lever if a billing bug would lock paying users
# out; usage is still recorded while disabled.
BILLING_ENFORCEMENT_ENABLED=true

# Wall-clock anchor for daily/monthly quota resets, in minutes offset from UTC.
# 330 = IST (UTC+5:30). Changing this shifts reset times for ALL users.
BILLING_TIMEZONE_OFFSET_MINUTES=330

# Plan code granted to users with no active subscription. Must exist in MongoDB.
DEFAULT_PLAN_CODE=free

# In-process plan catalogue cache TTL (ms). A price change takes up to this long
# to propagate across replicas. Set 0 to disable caching.
PLAN_CACHE_TTL_MS=60000

# Run billing cron jobs on this instance. Set false on all but ONE replica —
# the jobs are idempotent, so concurrent runs are safe but wasteful.
BILLING_CRON_ENABLED=true

# Retention windows for pruning (days).
USAGE_RETENTION_DAYS=90
EVENT_RETENTION_DAYS=180


# ─── Stripe (web checkout only — mobile uses RevenueCat) ──────────────────────
# Where: Stripe Dashboard → Developers → API keys / Webhooks.
# Optional: leave blank if you are not running the web payment rail.

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=


# ─── OpenAI (REQUIRED for AI chat) ────────────────────────────────────────────
# Where: platform.openai.com → API keys.

OPENAI_API_KEY=
OPENAI_ASSISTANT_ID=
OPENAI_MODEL=gpt-4o-mini


# ─── Google Sign-In ───────────────────────────────────────────────────────────
# Where: Google Cloud Console → APIs & Services → Credentials → OAuth client ID.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Email ────────────────────────────────────────────────────────────────────
# SMTP (Gmail app password, NOT your account password).
GMAIL_USER=
GMAIL_PASS=

# AWS SES / SNS. Where: AWS Console → IAM → Users → Security credentials.
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-south-1
AWS_SES_SOURCE_EMAIL=


# ─── Rate limiting ────────────────────────────────────────────────────────────

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
